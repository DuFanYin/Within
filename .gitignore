.venv/
venv/
__pycache__/
*.pyc
.python-version

# Full engine checkout produced by ./setup.sh (large).
third_party/cactus/

.env
.env.local

# Local SQLite (journal + moods); directory tracked via data/.gitkeep.
data/*
!data/.gitkeep

# Cactus RAG index cache next to corpus text; rebuilt on init.
corpus/data.bin
corpus/index.bin

# Journal/chat export snippets for RAG (local user content).
corpus/*.txt

# FFI library belongs under the engine checkout (cactus/build/), not vendored here.
lib/*.dylib
lib/*.so

.DS_Store

local/